<Window x:Class="YourApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Camera Manager" Height="520" Width="860">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Top">
            <Button x:Name="btnSearch" Content="검색" Width="90" Margin="0,0,8,0" Click="btnSearch_Click"/>
            <Button x:Name="btnApplyIp" Content="IP 적용" Width="90" Margin="0,0,8,0" Click="btnApplyIp_Click"/>
            <Button x:Name="btnConnect" Content="연결" Width="90" Margin="0,0,8,0" Click="btnConnect_Click"/>
            <Button x:Name="btnDisconnect" Content="연결 해제" Width="100" Click="btnDisconnect_Click"/>

            <Separator Margin="12,0,12,0" Width="1"/>

            <TextBlock VerticalAlignment="Center" Text="새 IP:" Margin="0,0,6,0"/>
            <TextBox x:Name="txtNewIp" Width="160" Margin="0,0,8,0" />

            <TextBlock VerticalAlignment="Center" Text="게이트웨이:" Margin="0,0,6,0"/>
            <TextBox x:Name="txtGateway" Width="160" Margin="0,0,8,0"/>

            <TextBlock VerticalAlignment="Center" Text="서브넷:" Margin="0,0,6,0"/>
            <TextBox x:Name="txtSubnet" Width="160"/>
        </StackPanel>

        <GroupBox Grid.Row="1" Header="검색된 카메라 목록" Margin="0,10,0,10">
            <Grid>
                <ListView x:Name="lvDevices" SelectionMode="Single" SelectionChanged="lvDevices_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Name" DisplayMemberBinding="{Binding DisplayName}" Width="220"/>
                            <GridViewColumn Header="Serial" DisplayMemberBinding="{Binding Serial}" Width="140"/>
                            <GridViewColumn Header="MAC" DisplayMemberBinding="{Binding Mac}" Width="150"/>
                            <GridViewColumn Header="IP" DisplayMemberBinding="{Binding Ip}" Width="130"/>
                            <GridViewColumn Header="Interface" DisplayMemberBinding="{Binding InterfaceType}" Width="110"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </GroupBox>

        <DockPanel Grid.Row="2">
            <TextBlock x:Name="txtStatus" Text="대기중" VerticalAlignment="Center"/>
        </DockPanel>
    </Grid>
</Window>
